@meta {
  id: "typescript-fullstack"
  syntax: "1.0.0"
  description: "Complete preset for TypeScript fullstack development"
}

@use @fullstackhouse/core-workflow
@use @fullstackhouse/code-style
@use @fullstackhouse/typescript
@use @fullstackhouse/git-commits
@use @fullstackhouse/testing
@use @fullstackhouse/context7

@standards {
  general: [
    "Be concise - no verbose explanations",
    "Simplicity First - make every change as simple as possible",
    "No Laziness - find root causes, no temporary fixes",
    "Minimal Impact - only touch what's necessary"
  ]
  prompts: [
    "When modifying AI prompts, distill to essence rather than copy-paste",
    "Keep concise if sufficient for AI comprehension",
    "Add 1-2 examples when needed for clarity"
  ]
}

@identity {
  """
  Expert TypeScript fullstack developer. Disciplined workflow with planning,
  clean code practices, proper testing, and conventional commits.
  Always use Context7 for library docs.
  """
}
